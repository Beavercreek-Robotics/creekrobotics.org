# ============================================================
#  Environment Variables — Beavercreek Robotics Site
# ============================================================
#
# Copy this file to .env.local (git-ignored) and fill in the
# values for your environment.  Never commit real secrets.
#
# Vite only exposes variables prefixed with VITE_ to the
# browser bundle.
# ============================================================

# -- Robot Events API key -----------------------------------
# Bearer token for the Robot Events API v2.
# Obtain your token at: https://www.robotevents.com/api/v2
# Without a token the API still works but is rate-limited.
VITE_ROBOTEVENTS_API_KEY=
